nuc.fritz.box {

    tls /certs/fullchain.pem /certs/nuc.fritz.box-key.pem

    handle /v1/* {
        reverse_proxy adapter:4000 {
            transport http {
                versions 1.1
            }
        }
    }

    handle /metrics {
        reverse_proxy adapter:4000
    }

    handle {
        reverse_proxy open-webui:8080
    }
}
