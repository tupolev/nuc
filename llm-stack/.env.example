OLLAMA_URL=http://host.docker.internal:11434
FILES_DIR=/data/files
AUTH_DB_PATH=/data/auth.db
API_KEY_SECRET=CHANGE_ME_API_KEY_SECRET
API_KEY_SALT=CHANGE_ME_API_KEY_SALT
CHAT_CONCURRENCY=2
EMBED_CONCURRENCY=1
QUEUE_TIMEOUT=30
TOOL_MAX_ITERATIONS=8
TOOL_ARG_MAX_LEN=50000
